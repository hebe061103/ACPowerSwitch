<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 参数配置 -->
        <TextView
            android:id="@+id/textView25"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="参数配置:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#78909C"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="HardcodedText" />

        <!-- 远程控制器IP -->
        <TextView
            android:id="@+id/textView21"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="远程控制器IP:"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView25"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/target_ip"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/target_ip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="0.0.0.0"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView21"
            app:layout_constraintStart_toEndOf="@id/textView21"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- 默认端口 -->
        <TextView
            android:id="@+id/textView22"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="默认端口:"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView21"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/target_port"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/target_port"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="55555"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView22"
            app:layout_constraintStart_toEndOf="@id/textView22"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- 负载功率阈值 -->
        <TextView
            android:id="@+id/textView7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="负载功率阈值设置(W):"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView22"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/w_edit"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/w_edit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="1000"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView7"
            app:layout_constraintStart_toEndOf="@id/textView7"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- 开启逆变阈值 -->
        <TextView
            android:id="@+id/textView20"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="开启逆变阈值(V):"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/open_pv_value"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/open_pv_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="26.8"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView20"
            app:layout_constraintStart_toEndOf="@id/textView20"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- 电池低压保护 -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="电池低压保护阈值(V):"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView20"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/low_voltage_set"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/low_voltage_set"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="24"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView"
            app:layout_constraintStart_toEndOf="@id/textView"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- 页面刷新时间 -->
        <TextView
            android:id="@+id/textView23"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="页面刷新时间设置(ms)"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/refresh_time_set"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/refresh_time_set"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="1000"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView23"
            app:layout_constraintStart_toEndOf="@id/textView23"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- MOS 风扇温度 -->
        <TextView
            android:id="@+id/textView30"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="主功率板风扇开启触发温度(℃):"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textView23"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/mos_trigger_value"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/mos_trigger_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="40"
            android:gravity="end"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/textView30"
            app:layout_constraintStart_toEndOf="@id/textView30"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            tools:ignore="HardcodedText" />

        <!-- 输出模式 -->
        <TextView
            android:id="@+id/custom_output"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="输出模式设定:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#78909C"
            app:layout_constraintTop_toBottomOf="@id/textView30"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="35dp"
            tools:ignore="HardcodedText" />

        <!-- 自动 / 市电 / 逆变 -->
        <TextView
            android:id="@+id/auto_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="自动模式"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/custom_output"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/power_grid_mode"
            android:layout_marginTop="25dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/power_grid_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="市电模式"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/auto_mode"
            app:layout_constraintStart_toEndOf="@id/auto_mode"
            app:layout_constraintEnd_toStartOf="@id/pv_mode"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/pv_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="逆变模式"
            android:gravity="end"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/auto_mode"
            app:layout_constraintStart_toEndOf="@id/power_grid_mode"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="HardcodedText" />

        <!-- 重置按钮 -->
        <TextView
            android:id="@+id/reset_network"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="重置网络及参数"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#AC0E07"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/auto_mode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="35dp"
            android:padding="12dp"
            tools:ignore="HardcodedText" />

        <!-- 说明 -->
        <TextView
            android:id="@+id/textView18"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="设置模块参数,包括双电源切换时的电压阈值,还有电池低压保护电压,默认情况下使用太阳能逆变做为主供电，当负载功率达到设定功率时，自动切换到市电做为输出."
            android:textSize="14sp"
            android:textColor="#78909C"
            app:layout_constraintTop_toBottomOf="@id/reset_network"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="25dp"
            tools:ignore="HardcodedText" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>